---
import Logo from "./Logo.astro";

type Item = { label: string; href: string; external?: boolean };

const product: Item[] = [
  { label: "Features", href: "/features" },
  { label: "Pricing", href: "/pricing" },
  { label: "Dashboard", href: "https://login.quickztna.com", external: true },
  { label: "Download", href: "https://login.quickztna.com/download", external: true },
];
const resources: Item[] = [
  { label: "Documentation", href: "https://docs.quickztna.com", external: true },
  { label: "Quickstart", href: "https://docs.quickztna.com/quickstart", external: true },
  { label: "API reference", href: "https://docs.quickztna.com/api", external: true },
  { label: "Security", href: "https://docs.quickztna.com/security", external: true },
];
const company: Item[] = [
  { label: "Sign in", href: "https://login.quickztna.com/auth", external: true },
  { label: "Sign up", href: "https://login.quickztna.com/auth", external: true },
  { label: "Contact sales", href: "mailto:sales@quickztna.com" },
  { label: "security@quickztna.com", href: "mailto:security@quickztna.com" },
];
const year = new Date().getFullYear();
---
<footer class="border-t border-border bg-surface">
  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
    <div class="grid gap-10 md:grid-cols-5">
      <div class="md:col-span-2">
        <Logo />
        <p class="mt-4 max-w-sm text-sm text-muted-foreground">
          Post-quantum-encrypted Zero Trust mesh. 100 devices connected in 2 minutes. Free forever on the starter plan.
        </p>
        <p class="mt-4 font-mono text-xs text-muted-foreground">
          <span class="text-success">●</span> All systems operational
        </p>
      </div>
      {[
        { title: "Product", items: product },
        { title: "Resources", items: resources },
        { title: "Company", items: company },
      ].map((col) => (
        <div>
          <h4 class="mb-3 font-mono text-xs font-semibold uppercase tracking-wider text-foreground">{col.title}</h4>
          <ul class="space-y-2 text-sm text-muted-foreground">
            {col.items.map((it) => (
              <li>
                <a
                  href={it.href}
                  target={it.external ? "_blank" : undefined}
                  rel={it.external ? "noopener noreferrer" : undefined}
                  class="hover:text-foreground"
                >
                  {it.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-border pt-6 text-xs text-muted-foreground md:flex-row md:items-center">
      <p>© {year} QuickZTNA — Post-quantum ZTNA for modern teams.</p>
      <div class="flex gap-4">
        <a href="/privacy" class="hover:text-foreground">Privacy</a>
        <a href="/terms" class="hover:text-foreground">Terms</a>
        <a href="https://docs.quickztna.com/security" target="_blank" rel="noopener noreferrer" class="hover:text-foreground">Security</a>
      </div>
    </div>
  </div>
</footer>
